{
  "id": "nl.desbeers.chordprovider",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.swift6"
  ],
  "command": "ChordProvider",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=wayland",
    "--filesystem=host",
    "--filesystem=xdg-run/pipewire-0"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/swift6/bin",
    "prepend-ld-library-path": "/usr/lib/sdk/swift6/lib"
  },
  "modules": [
    {
      "name": "fluidsynth",
      "buildsystem": "cmake-ninja",
      "config-opts": [
        "-Denable-sdl3=OFF"
      ],
      "sources": [
          {
              "type": "git",
              "url": "https://github.com/FluidSynth/fluidsynth.git",
              "tag": "v2.5.4",
              "commit": "57c19522838331da5aeae95433b0d776734907d8"
          }
      ]
    },
    {
      "name": "ChordProvider",
      "builddir": true,
      "buildsystem": "simple",
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ],
      "build-commands": [
        "swift build -c release --static-swift-stdlib --package-path ChordProviderGnome",
        "install -Dm755 ChordProviderGnome/.build/release/ChordProvider /app/bin/ChordProvider",
        "cp -r ChordProviderGnome/.build/release/ChordProvider_ChordProvider.resources/ /app/bin",
        "cp -r ChordProviderGnome/.build/release/ChordProviderCore_ChordProviderCore.resources/ /app/bin",
        "cp -r ChordProviderGnome/.build/release/ChordProvider_SourceView.resources/ /app/bin",
        "install -Dm644 ChordProviderGnome/Sources/ChordProvider/Resources/nl.desbeers.chordprovider.svg /app/share/icons/hicolor/scalable/apps/nl.desbeers.chordprovider.svg",
        "install -Dm644 ChordProviderGnome/Sources/ChordProvider/Resources/nl.desbeers.chordprovider-symbolic.svg /app/share/icons/hicolor/symbolic/apps/nl.desbeers.chordprovider-symbolic.svg",
        "install -Dm644 ChordProviderGnome/Sources/ChordProvider/Resources/nl.desbeers.chordprovider-mime.svg /app/share/icons/hicolor/scalable/mimetypes/nl.desbeers.chordprovider-doc.svg",
        "install -Dm644 ChordProviderGnome/data/nl.desbeers.chordprovider.metainfo.xml /app/share/metainfo/nl.desbeers.chordprovider.metainfo.xml",
        "install -Dm644 ChordProviderGnome/data/nl.desbeers.chordprovider.desktop /app/share/applications/nl.desbeers.chordprovider.desktop",
        "mkdir -p /app/share/mime/packages/",
        "install -m644 -p -t /app/share/mime/packages ChordProviderGnome/data/nl.desbeers.chordprovider.mime.xml",
        "update-mime-database /app/share/mime",
        "desktop-file-install --rebuild-mime-info-cache --dir=/app/share/applications /app/share/applications/nl.desbeers.chordprovider.desktop"
      ]
    }
  ]
}
